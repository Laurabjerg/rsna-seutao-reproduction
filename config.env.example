# Kopiér denne til config.env og ret paths.

PROJECT_ROOT=.
REPO_ROOT=./external/SeuTao_repo
DOWNLOAD_ROOT=./downloads
DATA_ROOT=./data

# Kaggle / RSNA rå DICOM-mapper
RSNA_STAGE1_TRAIN_DIR=/path/to/stage_1_train_images
RSNA_STAGE2_TEST_DIR=/path/to/stage_2_test_images

# Hvor de afledte filer skal ligge
RSNA_TRAIN_PNG_DIR=${DATA_ROOT}/train_png
RSNA_TEST_PNG_DIR=${DATA_ROOT}/test_png
RSNA_CONCAT_TRAIN_DIR=${DATA_ROOT}/train_concat_3images_256
RSNA_CONCAT_TEST_DIR=${DATA_ROOT}/stage2_test_concat_3images

# Sequence model
SEQUENCE_CSV_ROOT=${DATA_ROOT}/sequence_csv
SEQUENCE_FEATURE_ROOT=${DATA_ROOT}/features
SEQUENCE_FINAL_OUTPUT_ROOT=${DATA_ROOT}/FinalSubmission

# Downloads
PRETRAINED_ROOT=${DOWNLOAD_ROOT}/pretrained
AUX_DOWNLOAD_ROOT=${DOWNLOAD_ROOT}/auxiliary

# Optional
CUDA_VISIBLE_DEVICES=0