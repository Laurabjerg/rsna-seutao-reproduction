# Kopiér denne til config.env og ret paths.
# Alt nedenfor er relativt til PROJECT_ROOT og kræver normalt ingen ændringer.
# PROJECT_ROOT sættes automatisk af shell-scripts til den absolutte sti.

PROJECT_ROOT=${PROJECT_ROOT:-.}
SEUTAO_REPO_DIR=${PROJECT_ROOT}/external/SeuTao_repo
DOWNLOAD_DIR=${PROJECT_ROOT}/downloads
PRETRAIN_DIR=${DOWNLOAD_DIR}/pretrained
AUX_DATA_DIR=${DOWNLOAD_DIR}/auxiliary

# Rå RSNA DICOM-mapper (udfyldes automatisk af download_kaggle_data.py)
# NB: Kaggle har kun Stage 2 data. stage_2_train bruges som "train", stage_2_test som "test".
RSNA_TRAIN_DIR=${PROJECT_ROOT}/data/rsna_raw/stage_2_train
RSNA_TEST_DIR=${PROJECT_ROOT}/data/rsna_raw/stage_2_test

# Afledte filer
RSNA_TRAIN_PNG_DIR=${PROJECT_ROOT}/data/train_png
RSNA_TEST_PNG_DIR=${PROJECT_ROOT}/data/test_png
RSNA_CONCAT_TRAIN_DIR=${PROJECT_ROOT}/data/train_concat_3images_256
RSNA_CONCAT_TEST_DIR=${PROJECT_ROOT}/data/stage2_test_concat_3images

# Sequence model (paths inde i SeuTao-repoet)
SEQUENCE_CSV_ROOT=${SEUTAO_REPO_DIR}/SequenceModel/csv
SEQUENCE_FEATURE_ROOT=${SEUTAO_REPO_DIR}/SequenceModel/features
SEQUENCE_FINAL_OUTPUT_ROOT=${SEUTAO_REPO_DIR}/FinalSubmission

# Optional
CUDA_VISIBLE_DEVICES=0